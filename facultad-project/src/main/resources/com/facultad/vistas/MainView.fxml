<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/17" 
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.facultad.vistas.MainController">
    
    <!-- TOP: Menú Principal -->
    <top>
        <MenuBar>
            <Menu text="Archivo">
                <MenuItem text="Salir" onAction="#salir" />
            </Menu>
            <Menu text="Gestión">
                <MenuItem text="Institutos" onAction="#abrirInstitutos" />
                <MenuItem text="Docentes" onAction="#abrirDocentes" />
                <MenuItem text="Asignaturas" onAction="#abrirAsignaturas" />
                <SeparatorMenuItem />
                <MenuItem text="Carreras" />
                <MenuItem text="Cargos Docentes" />
            </Menu>
            <Menu text="Reportes">
                <MenuItem text="Listado General" />
                <MenuItem text="Estadísticas" />
            </Menu>
            <Menu text="Ayuda">
                <MenuItem text="Acerca de" onAction="#mostrarAcercaDe" />
            </Menu>
        </MenuBar>
    </top>
    
    <!-- CENTER: Dashboard -->
    <center>
        <VBox alignment="CENTER" spacing="30" style="-fx-background-color: #f5f7fa;">
            <VBox alignment="CENTER" spacing="10">
                <Label text="🏛️ SISTEMA DE GESTIÓN FACULTAD" 
                       style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" />
                <Label text="Trabajo Práctico Integrador - Universidad Nacional" 
                       style="-fx-font-size: 14px; -fx-text-fill: #7f8c8d;" />
            </VBox>
            
            <HBox alignment="CENTER" spacing="20">
                <!-- Tarjeta Institutos -->
                <VBox alignment="CENTER" spacing="10" 
                      style="-fx-background-color: #3498db; -fx-background-radius: 10; -fx-padding: 20; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.2), 10, 0, 0, 0);"
                      onMouseClicked="#abrirInstitutos">
                    <Label text="🏛️" style="-fx-font-size: 40px;" />
                    <Label text="INSTITUTOS" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: white;" />
                    <Label text="Gestionar unidades académicas" 
                           style="-fx-font-size: 12px; -fx-text-fill: rgba(255,255,255,0.9);" />
                </VBox>
                
                <!-- Tarjeta Docentes -->
                <VBox alignment="CENTER" spacing="10" 
                      style="-fx-background-color: #2ecc71; -fx-background-radius: 10; -fx-padding: 20; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.2), 10, 0, 0, 0);"
                      onMouseClicked="#abrirDocentes">
                    <Label text="👨‍🏫" style="-fx-font-size: 40px;" />
                    <Label text="DOCENTES" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: white;" />
                    <Label text="Gestionar plantel docente" 
                           style="-fx-font-size: 12px; -fx-text-fill: rgba(255,255,255,0.9);" />
                </VBox>
                
                <!-- Tarjeta Asignaturas -->
                <VBox alignment="CENTER" spacing="10" 
                      style="-fx-background-color: #e74c3c; -fx-background-radius: 10; -fx-padding: 20; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.2), 10, 0, 0, 0);"
                      onMouseClicked="#abrirAsignaturas">
                    <Label text="📚" style="-fx-font-size: 40px;" />
                    <Label text="ASIGNATURAS" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: white;" />
                    <Label text="Gestionar materias" 
                           style="-fx-font-size: 12px; -fx-text-fill: rgba(255,255,255,0.9);" />
                </VBox>
            </HBox>
            
            <!-- Estadísticas -->
            <VBox alignment="CENTER" spacing="10">
                <Label text="📊 RESUMEN DEL SISTEMA" 
                       style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" />
                <HBox alignment="CENTER" spacing="30">
                    <VBox alignment="CENTER" spacing="5" 
                          style="-fx-background-color: white; -fx-border-color: #3498db; -fx-border-width: 2; -fx-border-radius: 5; -fx-padding: 10;">
                        <Label text="3" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #3498db;" />
                        <Label text="Institutos" style="-fx-text-fill: #7f8c8d;" />
                    </VBox>
                    <VBox alignment="CENTER" spacing="5" 
                          style="-fx-background-color: white; -fx-border-color: #2ecc71; -fx-border-width: 2; -fx-border-radius: 5; -fx-padding: 10;">
                        <Label text="15" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2ecc71;" />
                        <Label text="Docentes" style="-fx-text-fill: #7f8c8d;" />
                    </VBox>
                    <VBox alignment="CENTER" spacing="5" 
                          style="-fx-background-color: white; -fx-border-color: #e74c3c; -fx-border-width: 2; -fx-border-radius: 5; -fx-padding: 10;">
                        <Label text="42" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #e74c3c;" />
                        <Label text="Asignaturas" style="-fx-text-fill: #7f8c8d;" />
                    </VBox>
                </HBox>
            </VBox>
            
            <!-- Acceso rápido -->
            <HBox alignment="CENTER" spacing="10">
                <Button text="Nuevo Instituto" style="-fx-background-color: #3498db; -fx-text-fill: white;" 
                        onAction="#abrirInstitutos" />
                <Button text="Nuevo Docente" style="-fx-background-color: #2ecc71; -fx-text-fill: white;" 
                        onAction="#abrirDocentes" />
                <Button text="Nueva Asignatura" style="-fx-background-color: #e74c3c; -fx-text-fill: white;" 
                        onAction="#abrirAsignaturas" />
            </HBox>
        </VBox>
    </center>
    
    <!-- BOTTOM: Barra de estado -->
    <bottom>
        <HBox style="-fx-background-color: #ecf0f1; -fx-padding: 5;">
            <Label text="✅ Sistema conectado a PostgreSQL | Usuario: Admin" 
                   style="-fx-text-fill: #7f8c8d;" />
        </HBox>
    </bottom>
    
</BorderPane>