<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx/17" 
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.facultad.vistas.DocenteController">
    
    <!-- TOP: Título y navegación -->
    <top>
        <HBox spacing="10" style="-fx-padding: 10; -fx-background-color: #2ecc71;">
            <Button text="← Volver" style="-fx-background-color: white; -fx-text-fill: #2ecc71;" 
                    onAction="#volverAlMenu" />
            <Label text="👨‍🏫 GESTIÓN DE DOCENTES" 
                   style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: white;" />
        </HBox>
    </top>
    
    <!-- CENTER: Contenido principal -->
    <center>
        <SplitPane dividerPositions="0.4">
            
            <!-- LEFT: Formulario y detalles -->
            <VBox spacing="15" style="-fx-padding: 20;">
                <Label text="📝 FORMULARIO DE DOCENTE" 
                       style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" />
                
                <!-- Formulario básico -->
                <GridPane hgap="10" vgap="10">
                    <Label text="Documento:" GridPane.rowIndex="0" GridPane.columnIndex="0" />
                    <TextField fx:id="txtDocumento" promptText="Ej: 12345678" 
                               GridPane.rowIndex="0" GridPane.columnIndex="1" GridPane.hgrow="ALWAYS" />
                    
                    <Label text="Nombres:" GridPane.rowIndex="1" GridPane.columnIndex="0" />
                    <TextField fx:id="txtNombres" promptText="Ej: Juan Carlos" 
                               GridPane.rowIndex="1" GridPane.columnIndex="1" GridPane.hgrow="ALWAYS" />
                    
                    <Label text="Apellidos:" GridPane.rowIndex="2" GridPane.columnIndex="0" />
                    <TextField fx:id="txtApellidos" promptText="Ej: Pérez González" 
                               GridPane.rowIndex="2" GridPane.columnIndex="1" GridPane.hgrow="ALWAYS" />
                    
                    <Label text="Fecha Nacimiento:" GridPane.rowIndex="3" GridPane.columnIndex="0" />
                    <DatePicker fx:id="dateFechaNacimiento" promptText="dd/mm/aaaa" 
                                GridPane.rowIndex="3" GridPane.columnIndex="1" />
                    
                    <Label text="Dirección:" GridPane.rowIndex="4" GridPane.columnIndex="0" />
                    <TextField fx:id="txtDireccion" promptText="Ej: Calle Falsa 123" 
                               GridPane.rowIndex="4" GridPane.columnIndex="1" GridPane.hgrow="ALWAYS" />
                </GridPane>
                
                <!-- Botones CRUD -->
                <HBox spacing="10">
                    <Button text="➕ Guardar" fx:id="btnGuardar" 
                            style="-fx-background-color: #2ecc71; -fx-text-fill: white;" 
                            onAction="#guardarDocente" prefWidth="100" />
                    <Button text="✏️ Editar" fx:id="btnEditar" 
                            style="-fx-background-color: #f39c12; -fx-text-fill: white;" 
                            onAction="#editarDocente" prefWidth="100" disable="true" />
                    <Button text="🗑️ Eliminar" fx:id="btnEliminar" 
                            style="-fx-background-color: #e74c3c; -fx-text-fill: white;" 
                            onAction="#eliminarDocente" prefWidth="100" disable="true" />
                    <Button text="🔁 Limpiar" 
                            style="-fx-background-color: #95a5a6; -fx-text-fill: white;" 
                            onAction="#limpiarFormulario" prefWidth="100" />
                </HBox>
                
                <!-- Mensajes de validación -->
                <Label fx:id="lblMensaje" style="-fx-text-fill: #e74c3c;" wrapText="true" />
                
                <!-- Separador -->
                <Separator />
                
                <!-- Cargos del docente -->
                <Label text="🏛️ CARGOS ASIGNADOS" 
                       style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" />
                
                <TableView fx:id="tablaCargos" prefHeight="150">
                    <columns>
                        <TableColumn text="Instituto" fx:id="colInstitutoCargo" prefWidth="150" />
                        <TableColumn text="Horas" fx:id="colHorasCargo" prefWidth="80" />
                        <TableColumn text="Acciones" fx:id="colAccionesCargo" prefWidth="100" />
                    </columns>
                </TableView>
                
                <!-- Botones para cargos -->
<!-- Botones para cargos -->
<HBox spacing="10">
    <Button text="➕ Asignar Cargo" onAction="#abrirDialogoAsignarCargo" 
            style="-fx-background-color: #3498db; -fx-text-fill: white;" />
    <Button text="🗑️ Quitar Cargo" fx:id="btnQuitarCargo" 
            onAction="#quitarCargoSeleccionado" 
            style="-fx-background-color: #e74c3c; -fx-text-fill: white;" disable="true" />
</HBox>
            </VBox>
            
            <!-- RIGHT: Tabla de docentes y búsqueda -->
            <VBox spacing="10" style="-fx-padding: 20;">
                <Label text="📊 DOCENTES REGISTRADOS" 
                       style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" />
                
                <!-- Filtros de búsqueda -->
                <VBox spacing="5" style="-fx-padding: 10; -fx-background-color: #f8f9fa; -fx-border-color: #ddd; -fx-border-radius: 5;">
                    <Label text="🔍 FILTROS DE BÚSQUEDA" style="-fx-font-weight: bold;" />
                    <HBox spacing="10">
                        <TextField fx:id="txtBuscarApellido" promptText="Buscar por apellido..." HBox.hgrow="ALWAYS" />
                        <TextField fx:id="txtBuscarDocumento" promptText="Buscar por documento..." />
                    </HBox>
                    <HBox spacing="10">
                        <Button text="🔍 Buscar" onAction="#buscarDocentes" />
                        <Button text="🔄 Recargar Todos" onAction="#cargarDocentes" />
                    </HBox>
                </VBox>
                
                <!-- Tabla principal -->
                <TableView fx:id="tablaDocentes" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn text="Legajo" fx:id="colLegajo" prefWidth="80" />
                        <TableColumn text="Documento" fx:id="colDocumento" prefWidth="120" />
                        <TableColumn text="Apellidos" fx:id="colApellidos" prefWidth="150" />
                        <TableColumn text="Nombres" fx:id="colNombres" prefWidth="150" />
                        <TableColumn text="Edad" fx:id="colEdad" prefWidth="70" />
                        <TableColumn text="Cargos" fx:id="colCantidadCargos" prefWidth="80" />
                    </columns>
                </TableView>
                
                <!-- Información del docente seleccionado -->
                <VBox spacing="5" style="-fx-padding: 10; -fx-background-color: #ecf0f1; -fx-border-radius: 5;">
                    <Label text="👤 INFORMACIÓN DETALLADA" style="-fx-font-weight: bold;" />
                    <GridPane hgap="10" vgap="5">
                        <Label text="Legajo:" GridPane.rowIndex="0" GridPane.columnIndex="0" />
                        <Label fx:id="lblDetalleLegajo" GridPane.rowIndex="0" GridPane.columnIndex="1" />
                        
                        <Label text="Documento:" GridPane.rowIndex="1" GridPane.columnIndex="0" />
                        <Label fx:id="lblDetalleDocumento" GridPane.rowIndex="1" GridPane.columnIndex="1" />
                        
                        <Label text="Nombre completo:" GridPane.rowIndex="2" GridPane.columnIndex="0" />
                        <Label fx:id="lblDetalleNombreCompleto" GridPane.rowIndex="2" GridPane.columnIndex="1" />
                        
                        <Label text="Fecha nacimiento:" GridPane.rowIndex="3" GridPane.columnIndex="0" />
                        <Label fx:id="lblDetalleFechaNacimiento" GridPane.rowIndex="3" GridPane.columnIndex="1" />
                        
                        <Label text="Dirección:" GridPane.rowIndex="4" GridPane.columnIndex="0" />
                        <Label fx:id="lblDetalleDireccion" GridPane.rowIndex="4" GridPane.columnIndex="1" />
                    </GridPane>
                </VBox>
            </VBox>
            
        </SplitPane>
    </center>
    
    <!-- BOTTOM: Barra de estado -->
    <bottom>
        <HBox style="-fx-background-color: #ecf0f1; -fx-padding: 5;">
            <Label fx:id="lblEstado" text="Listo" style="-fx-text-fill: #7f8c8d;" />
        </HBox>
    </bottom>
    
</BorderPane>